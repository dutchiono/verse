HELIUS_API_KEY="paste-your-helius-api-key-here"
SERVER_PORT=7000
SERVER_HOST=127.0.0.1
# Optional dashboard port (defaults in web/vite.config.ts to 7003)
# VITE_PORT=7003

# Set this to auto-unlock on startup so you never have to type the vault password in the dashboard.
# Requires ALLOW_AUTO_UNLOCK=1 to be set — both must be present.
# Useful for local dev / test wallets. Leave blank (or delete the line) for production.
# AUTO_UNLOCK_PASSWORD=your-vault-password-here
# ALLOW_AUTO_UNLOCK=1

# Optional overrides if Jupiter changes hosts (defaults: api.jup.ag swap v1)
# JUPITER_QUOTE_URL=https://api.jup.ag/swap/v1/quote
# JUPITER_SWAP_URL=https://api.jup.ag/swap/v1/swap
